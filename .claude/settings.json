{
  "permissions": {
    "allow": [
      "Bash(bash /workspace/v24-build.sh:*)",
      "Bash(bash /workspace/v24-build-clean.sh:*)",
      "Bash(bash /workspace/v24-server-start.sh:*)",
      "Bash(bash /workspace/v24-server-stop.sh:*)",
      "Bash(bash /workspace/v24-server-logs.sh:*)",
      "Bash(bash /workspace/v24-server-status.sh:*)",
      "Bash(bash /workspace/v25-build.sh:*)",
      "Bash(bash /workspace/v25-build-clean.sh:*)",
      "Bash(bash /workspace/v25-server-start.sh:*)",
      "Bash(bash /workspace/v25-server-stop.sh:*)",
      "Bash(mvn test:*)",
      "Bash(mvn clean install:*)",
      "Bash(mvn clean package:*)",
      "Bash(mvn compile:*)",
      "Bash(mvn clean compile:*)",
      "Bash(mvn install:*)",
      "Bash(mvn -pl:*)",
      "Bash(mvn spotless:check:*)",
      "Bash(npx playwright test:*)",
      "Bash(npm test:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git -C /workspace status:*)",
      "Bash(git -C /workspace diff:*)",
      "Bash(git -C /workspace log:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/scripts/notify.sh"
          }
        ]
      }
    ]
  }
}
